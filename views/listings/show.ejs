<% layout("layouts/boilerplate") %>

    <div class="py-5">
        <div class="row gx-5 align-items-start">
            <div class="col-lg-6">
                <div class="card card-custom overflow-hidden">
                    <img src="<%= data.image.url %>" class="card-img-top" alt="<%= data.title %> image"
                        style="height: 420px;">
                    <div class="card-body">
                        <h2 class="mb-3">
                            <%= data.title %>
                        </h2>
                        <p class="text-muted mb-4">
                            <%= data.location %>, <%= data.country %>
                        </p>
                        <i>
                            <p>Owner: <%= data.owner ? data.owner.username : 'Unknown owner' %>
                            </p>
                        </i>
                        <p class="fs-5 text-secondary mb-4">
                            <%= data.description %>
                        </p>

                        <dl class="row listing-meta mb-4">
                            <dt class="col-4">Price</dt>
                            <dd class="col-8">₹ <%= data.price.toLocaleString("en-IN") %>
                            </dd>
                            <dt class="col-4">Location</dt>
                            <dd class="col-8">
                                <%= data.location %>
                            </dd>
                            <dt class="col-4">Country</dt>
                            <dd class="col-8">
                                <%= data.country %>
                            </dd>
                        </dl>
                        <% if(currentUser && data.owner && currentUser._id.equals(data.owner._id)){ %>
                            <div class="d-flex flex-wrap gap-3">
                                <form method="get" action="/listings/<%= data._id %>/edit">
                                    <button class="btn btn-primary">Edit</button>
                                </form>
                                <form method="post" action="/listings/<%= data._id %>?_method=DELETE">
                                    <button class="btn btn-outline-danger">Delete</button>
                                </form>
                            </div>
                            <%}%>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mt-5 mt-lg-0">
                <% if(currentUser) {%>
                    <div class="card card-custom p-4">
                        <h3 class="mb-4">Leave a Review</h3>
                        <form action="/listings/<%= data._id %>/review" method="post" novalidate
                            class="needs-validation">
                            <div class="mb-3">
                                <label class="form-label">Comment</label>
                                <textarea class="form-control" rows="5" placeholder="Write your review here..." required
                                    name="review[Comment]"></textarea>
                                <div class="invalid-feedback">Please submit a comment for review.</div>
                            </div>

                            <div class="mb-4">
                                <fieldset class="starability-heart">
                                    <legend>Rating:</legend>
                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                        aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" checked />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <button type="submit" class="btn btn-primary">Submit Review</button>
                        </form>
                    </div>
                    <% } %>

                        <div class="mt-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="mb-0">Reviews</h3>
                                <small class="text-muted">
                                    <%= data.reviews.length %> total
                                </small>
                            </div>

                            <% if (data.reviews.length===0) { %>
                                <div class="alert alert-no-reviews">No reviews yet. Be the first to review this listing.
                                </div>
                                <% } %>

                                    <div class="row g-3">
                                        <% for (let rev of data.reviews) { %>
                                            <div class="col-md-6">
                                                <div class="review-card p-4 h-100">
                                                    <div
                                                        class="review-card-header d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
                                                        <div class="review-card-author">
                                                            <span>
                                                                <%= rev.author ? rev.author.username : 'Anonymous' %>
                                                            </span>
                                                        </div>
                                                        <div class="review-card-meta d-flex align-items-center gap-3">
                                                            <span class="badge review-rating">⭐ <%= rev.rating %>
                                                                    /5</span>
                                                            <small class="text-muted">Review</small>
                                                        </div>
                                                    </div>
                                                    <p class="review-card-text text-muted mb-4">
                                                        <%= rev.Comment %>
                                                    </p>
                                                    <form method="post"
                                                        action="/listings/<%= data._id %>/review/<%= rev._id %>?_method=DELETE">
                                                        <button class="btn btn-outline-danger btn-sm">Delete</button>
                                                    </form>
                                                </div>
                                            </div>
                                            <% } %>
                                    </div>
                        </div>
            </div>
        </div>
    </div>
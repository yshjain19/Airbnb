<% layout("..views\layouts\boilerplate.ejs") %>
    <div class="row">
        <div class="col-8 offset-2">


            <br> <br>
            <h1>Edit your post</h1>
            <br> <br>
            <form method="post" action="/listings/<%= post._id.toString() %>?_method=PUT" class="needs-validation"
                novalidate>
                <div>
                    <label for="title" class="form-label"><b>Title</b></label>
                    <input type="text" name="title" value="<%=post.title%>" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter a title</div>
                    <br> <br>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label" rows="5" cols="40"><b>description</b></label>
                    <textarea name="description" class="form-control" style="height: 150px;"
                        required><%= post.description %></textarea>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter description</div>
                    <br> <br>

                </div>
                <div>
                    <label for="image" class="form-label">image</label>
                    <input type="text" name="image" value="<%=post.image.url%>" class="form-control">
                    <div class="valid-feedback">Looks good!</div>
                    <br> <br>
                </div>
                <div>
                    <label for="price" class="form-label">price</label>
                    <input type="number" name="price" value="<%=post.price%>" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter price</div>
                    <br> <br>
                </div>
                <div>
                    <label for="country" class="form-label">country</label>
                    <input type="text" name="country" value="<%=post.country%>" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter country</div>
                    <br> <br>
                </div>
                <div>
                    <label for="location" class="form-label">location</label>
                    <input type="text" name="location" value="<%=post.location%>" class="form-control" required>
                    <div class="valid-feedback">Looks good!</div>
                    <div class="invalid-feedback">Please enter location</div>
                    <br>
                    <br>
                </div>
                <button type="submit">submit</button>
            </form>
        </div>
    </div>
    <br> <br>
    <script src="/JS/script.js"></script>